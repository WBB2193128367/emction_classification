# ====================
# IDE 配置（不要提交，每个开发者自己的配置不同）
# ====================
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ====================
# Python 缓存文件
# ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ====================
# 虚拟环境
# ====================
venv/
env/
ENV/
.venv
.env

# ====================
# 大模型文件（文件太大，不适合放 Git 普通仓库）
# 建议用 Git LFS 或单独存储
# ====================
*.safetensors
*.bin
*.pth
*.pt
*.h5
*.ckpt
*.pkl

# ====================
# 日志和临时文件
# ====================
*.log
*.tmp
*.temp
*.bak
*.backup

# ====================
# 操作系统生成的文件
# ====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ====================
# 测试和覆盖率
# ====================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ====================
# Jupyter Notebook
# ====================
.ipynb_checkpoints/

# ====================
# 分发/打包文件
# ====================
build/
dist/
*.egg-info/
*.egg

# ====================
# 数据库文件
# ====================
*.db
*.sqlite
*.sqlite3

# ====================
# 配置文件中的敏感信息（如果有）
# ====================
*.secret
*.key
*.pem
*.crt

# ====================
# 资源目录中的大文件（可选）
# 如果 resource/ 下有很多大文件不想提交
# ====================
# resource/model/*.pth
# resource/model/*.bin

# ====================
# 摄像头/图像缓存
# ====================
*.jpg.cache
*.png.cache
captures/
frames/